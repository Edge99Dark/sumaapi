<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %></title>
    <!-- CSS desde la carpeta public/css/ -->
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <div class="container">
        <h1>🧮 <%= titulo %></h1>
        <p>Ingresa dos números para sumarlos usando la API</p>
        
        <div class="form-group">
            <div class="input-group">
                <label for="numero1">Número 1:</label>
                <input type="number" id="numero1" placeholder="Ej: 5" step="any" required>
            </div>
            
            <div class="input-group">
                <label for="numero2">Número 2:</label>
                <input type="number" id="numero2" placeholder="Ej: 3" step="any" required>
            </div>
            
            <button id="btnSumar">
                <span>➕</span> Sumar
            </button>
        </div>
        
        <!-- Mostrar resultado si existe -->
        <% if (resultado) { %>
        <div id="resultado" class="resultado exito">
            <div style="text-align: center; width: 100%;">
                <p style="font-size: 14px; color: #155724; margin-bottom: 5px;">✅ La suma es:</p>
                <div style="font-size: 24px; margin-top: 5px;">
                    <strong><%= resultado.numero1 %></strong> + <strong><%= resultado.numero2 %></strong> = 
                    <strong style="color: #28a745; font-size: 32px;"><%= resultado.resultado %></strong>
                </div>
            </div>
        </div>
        <% } else { %>
        <div id="resultado" class="resultado">
            <p>El resultado aparecerá aquí</p>
        </div>
        <% } %>
        
        <!-- Mostrar error si existe -->
        <% if (error) { %>
        <div id="resultado" class="resultado error">
            <p>❌ <%= error %></p>
        </div>
        <% } %>
        
        <div id="loading" class="loading" style="display: none;">
            <div class="spinner"></div>
            <p>Calculando...</p>
        </div>
    </div>

    <!-- JavaScript desde la carpeta public/js/ -->
    <script src="js/script.js"></script>
</body>
</html>